pipeline {
    agent none

    stages {
        stage('Get Code') {
            agent { label 'utility-agent' }

            steps {
                cleanWs()

                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                git 'https://github.com/siberett/helloworld.git'

                stash name: 'source-code', includes: '**/*'
            }

            post {
                always {
                    cleanWs()
                }
            }
        }

        stage('Parallel Checks') {
            parallel {
                stage('Rest') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                set +e

                                export PYTHONPATH="$WORKSPACE"

                                flask --app app.api:api_application run --host 127.0.0.1 --port 5001 > flask.log 2>&1 &
                                FLASK_PID=$!

                                trap "kill $FLASK_PID 2>/dev/null || true" EXIT

                                for i in $(seq 1 30); do
                                    if curl -fsS http://127.0.0.1:5001/calc/add/1/2 >/dev/null; then
                                        break
                                    fi
                                    sleep 1
                                done

                                curl -fsS http://wiremock:8080/calc/sqrt/64

                                APP_BASE_URL=http://127.0.0.1:5001 \\
                                WIREMOCK_BASE_URL=http://wiremock:8080 \\
                                pytest --junitxml=result-rest.xml test/rest

                                exit 0
                            '''
                        }

                        junit allowEmptyResults: true,
                              testResults: 'result-rest.xml',
                              skipMarkingBuildUnstable: true
                    }

                    post {
                        always {
                            stash name: 'rest-results',
                                  includes: 'result-rest.xml,flask.log',
                                  allowEmpty: true

                            cleanWs()
                        }
                    }
                }

                stage('Unit') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                export PYTHONPATH="$WORKSPACE"

                                coverage run --branch --source=app --omit=app/__init__.py,app/api.py -m pytest --junitxml=result-unit.xml test/unit
                                coverage xml
                            '''
                        }

                        junit allowEmptyResults: true,
                              testResults: 'result-unit.xml',
                              skipMarkingBuildUnstable: true

                        stash name: 'coverage-report',
                              includes: 'coverage.xml,result-unit.xml',
                              allowEmpty: true
                    }

                    post {
                        always {
                            cleanWs()
                        }
                    }
                }

                stage('Static') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                flake8 --exit-zero --format=pylint app > flake8.out
                            '''
                        }

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            recordIssues(
                                tools: [flake8(name: 'Flake8', pattern: 'flake8.out')],
                                qualityGates: [
                                    [threshold: 10, type: 'TOTAL', unstable: false],
                                    [threshold: 8, type: 'TOTAL', unstable: true]
                                ]
                            )
                        }
                    }

                    post {
                        always {
                            stash name: 'static-results',
                                  includes: 'flake8.out',
                                  allowEmpty: true

                            cleanWs()
                        }
                    }
                }

                stage('Security') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                bandit --exit-zero -r . -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
                            '''
                        }

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            recordIssues(
                                tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')],
                                qualityGates: [
                                    [threshold: 4, type: 'TOTAL', unstable: false],
                                    [threshold: 2, type: 'TOTAL', unstable: true]
                                ]
                            )
                        }
                    }

                    post {
                        always {
                            stash name: 'security-results',
                                  includes: 'bandit.out',
                                  allowEmpty: true

                            cleanWs()
                        }
                    }
                }

                stage('Performance') {
                    agent { label 'performance-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                set -e

                                export PYTHONPATH="$WORKSPACE"

                                flask --app app.api:api_application run --host 127.0.0.1 --port 5001 > flask-performance.log 2>&1 &
                                FLASK_PID=$!

                                trap "kill $FLASK_PID 2>/dev/null || true" EXIT

                                for i in $(seq 1 30); do
                                    if curl -fsS http://127.0.0.1:5001/calc/add/1/2 >/dev/null; then
                                        break
                                    fi
                                    sleep 1
                                done

                                jmeter -n -t test/jmeter/flask.jmx -f -l flask.jtl
                            '''
                        }

                        perfReport sourceDataFiles: 'flask.jtl'
                    }

                    post {
                        always {
                            stash name: 'performance-results',
                                  includes: 'flask.jtl,flask-performance.log',
                                  allowEmpty: true

                            cleanWs()
                        }
                    }
                }
            }
        }

        stage('Coverage') {
            agent { label 'python-agent' }

            steps {
                cleanWs()

                unstash 'source-code'
                unstash 'coverage-report'

                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    recordCoverage(
                        tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']],
                        qualityGates: [
                            [threshold: 85.0, metric: 'LINE', baseline: 'PROJECT', criticality: 'FAILURE'],
                            [threshold: 95.0, metric: 'LINE', baseline: 'PROJECT', criticality: 'UNSTABLE'],

                            [threshold: 80.0, metric: 'BRANCH', baseline: 'PROJECT', criticality: 'FAILURE'],
                            [threshold: 90.0, metric: 'BRANCH', baseline: 'PROJECT', criticality: 'UNSTABLE']
                        ],
                        sourceCodeRetention: 'LAST_BUILD'
                    )
                }
            }

            post {
                always {
                    stash name: 'coverage-results',
                          includes: 'coverage.xml,result-unit.xml',
                          allowEmpty: true

                    cleanWs()
                }
            }
        }

        stage('Publish Results') {
            agent { label 'utility-agent' }

            steps {
                cleanWs()

                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                script {
                    [
                        'rest-results',
                        'coverage-results',
                        'static-results',
                        'security-results',
                        'performance-results'
                    ].each { stashName ->
                        try {
                            unstash stashName
                        } catch (err) {
                            echo "No se pudo recuperar stash '${stashName}': ${err}"
                        }
                    }
                }

                archiveArtifacts artifacts: 'result-rest.xml,result-unit.xml,coverage.xml,flake8.out,bandit.out,flask.log,flask-performance.log,flask.jtl',
                                 allowEmptyArchive: true
            }

            post {
                always {
                    cleanWs()
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline multiagente finalizado.'
        }
    }
}

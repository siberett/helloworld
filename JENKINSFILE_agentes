pipeline {
    // agent none evita reservar un executor global durante todo el pipeline.
    // Cada etapa solicita solo el agente necesario para su tipo de trabajo.
    agent none

    options {
        skipDefaultCheckout(true)
        timestamps()
    }

    stages {
        stage('Get Code') {
            agent { label 'utility-agent' }

            steps {
                cleanWs()

                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                git 'https://github.com/siberett/helloworld.git'

                // Los workspaces no se comparten automaticamente entre agentes.
                // Se guarda el codigo para recuperarlo en cada rama paralela.
                stash name: 'source-code',
                    includes: '**/*,.flake8',
                    excludes: '.git/**,.venv/**,.pytest_cache/**,**/__pycache__/**',
                    useDefaultExcludes: false
            }

            post {
                always {
                    cleanWs()
                }
            }
        }

        stage('Parallel Checks') {
            parallel {
                stage('Rest') {
                    // Rest, Coverage, Static y Security comparten python-agent
                    // porque todas son tareas Python y usan el mismo entorno base.
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                set +e

                                export PYTHONPATH="$WORKSPACE"

                                flask --app app.api:api_application run --host 127.0.0.1 --port 5001 > flask.log 2>&1 &
                                FLASK_PID=$!

                                trap "kill $FLASK_PID 2>/dev/null || true" EXIT

                                for i in $(seq 1 30); do
                                    if curl -fsS http://127.0.0.1:5001/calc/add/1/2 >/dev/null; then
                                        break
                                    fi
                                    sleep 1
                                done

                                curl -fsS http://wiremock:8080/calc/sqrt/64

                                APP_BASE_URL=http://127.0.0.1:5001 \\
                                WIREMOCK_BASE_URL=http://wiremock:8080 \\
                                pytest --junitxml=result-rest.xml test/rest

                                exit 0
                            '''
                        }

                        junit allowEmptyResults: true, testResults: 'result-rest.xml'
                    }

                    post {
                        always {
                            stash name: 'rest-results',
                                includes: 'result-rest.xml,flask.log',
                                allowEmpty: true
                            cleanWs()
                        }
                    }
                }

                stage('Coverage') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                export PYTHONPATH="$WORKSPACE"

                                coverage run --branch --source=app --omit=app/__init__.py,app/api.py -m pytest --junitxml=result-unit.xml test/unit || true
                                coverage xml
                            '''
                        }

                        junit 'result-unit.xml'

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            recordCoverage(
                                tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']],
                                qualityGates: [
                                    [threshold: 85.0, metric: 'LINE', baseline: 'PROJECT', unstable: false],
                                    [threshold: 95.0, metric: 'LINE', baseline: 'PROJECT', unstable: true],

                                    [threshold: 80.0, metric: 'BRANCH', baseline: 'PROJECT', unstable: false],
                                    [threshold: 90.0, metric: 'BRANCH', baseline: 'PROJECT', unstable: true]
                                ],
                                sourceCodeRetention: 'LAST_BUILD'
                            )
                        }
                    }

                    post {
                        always {
                            stash name: 'coverage-results',
                                includes: 'result-unit.xml,coverage.xml',
                                allowEmpty: true
                            cleanWs()
                        }
                    }
                }

                stage('Static') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                flake8 --exit-zero --format=pylint app > flake8.out
                            '''
                        }

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            recordIssues(
                                tools: [flake8(name: 'Flake8', pattern: 'flake8.out')],
                                qualityGates: [
                                    [threshold: 10, type: 'TOTAL', unstable: false],
                                    [threshold: 8, type: 'TOTAL', unstable: true]
                                ]
                            )
                        }
                    }

                    post {
                        always {
                            stash name: 'static-results',
                                includes: 'flake8.out',
                                allowEmpty: true
                            cleanWs()
                        }
                    }
                }

                stage('Security') {
                    agent { label 'python-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                bandit --exit-zero -r . -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
                            '''
                        }

                        recordIssues(
                            tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')],
                            qualityGates: [
                                [threshold: 4, type: 'TOTAL', unstable: false],
                                [threshold: 2, type: 'TOTAL', unstable: true]
                            ]
                        )
                    }

                    post {
                        always {
                            stash name: 'security-results',
                                includes: 'bandit.out',
                                allowEmpty: true
                            cleanWs()
                        }
                    }
                }

                stage('Performance') {
                    agent { label 'performance-agent' }

                    steps {
                        cleanWs()
                        unstash 'source-code'

                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh '''
                                whoami
                                hostname
                                echo ${WORKSPACE}

                                set -e

                                export PYTHONPATH="$WORKSPACE"

                                flask --app app.api:api_application run --host 127.0.0.1 --port 5001 > flask-performance.log 2>&1 &
                                FLASK_PID=$!

                                trap "kill $FLASK_PID 2>/dev/null || true" EXIT

                                for i in $(seq 1 30); do
                                    if curl -fsS http://127.0.0.1:5001/calc/add/1/2 >/dev/null; then
                                        break
                                    fi
                                    sleep 1
                                done

                                jmeter -n -t test/jmeter/flask.jmx -f -l flask.jtl
                            '''
                        }

                        perfReport sourceDataFiles: 'flask.jtl'
                    }

                    post {
                        always {
                            stash name: 'performance-results',
                                includes: 'flask.jtl,flask-performance.log',
                                allowEmpty: true
                            cleanWs()
                        }
                    }
                }
            }
        }

        stage('Publish Results') {
            agent { label 'utility-agent' }

            steps {
                cleanWs()

                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                script {
                    [
                        'source-code',
                        'rest-results',
                        'coverage-results',
                        'static-results',
                        'security-results',
                        'performance-results'
                    ].each { stashName ->
                        try {
                            unstash stashName
                        } catch (err) {
                            echo "No se pudo recuperar stash '${stashName}': ${err}"
                        }
                    }
                }

                archiveArtifacts artifacts: 'result-rest.xml,result-unit.xml,coverage.xml,flake8.out,bandit.out,flask.log,flask-performance.log,flask.jtl',
                    allowEmptyArchive: true
            }

            post {
                always {
                    cleanWs()
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline multiagente finalizado.'
        }
    }
}
